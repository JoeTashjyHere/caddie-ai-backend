# Caddie.AI Backend Environment
# Copy to .env and fill in values. Never commit .env.

# Database (required for course intelligence and recommendation analytics)
DATABASE_URL=postgresql://user:password@localhost:5432/caddie

# Google Places API (required for course search)
GOOGLE_PLACES_API_KEY=

# OpenAI (for recommendations)
OPENAI_API_KEY=

# Server
PORT=8080

# Startup: run ingestion when tables are empty (default: false)
RUN_INGEST_ON_START=false

# Data source: local (filesystem) or url (fetch from URL)
DATA_SOURCE_TYPE=local
DATA_SOURCE_PATH=./data
